# ---------------------------------------------------------------------------
# TimeNest configuration
# Copy this file to `.env` and edit the values below. The stack reads `.env`
# automatically via docker-compose. Do NOT commit your `.env`.
# ---------------------------------------------------------------------------

# Absolute path on the host to the external drive you want to use as the
# Time Machine target. Must already be mounted. Create it with:
#   sudo mkdir -p /mnt/timenest
#   # add an fstab entry, then:
#   sudo mount -a
BACKUP_PATH=/mnt/timenest

# Name advertised via Bonjour. Shown in Finder and Time Machine settings.
SERVER_NAME=TimeNest

# Hardware model reported to macOS. Affects the icon Finder uses.
# Values that work well: TimeCapsule8,119 (Time Capsule icon),
# Xserve (server icon), MacPro7,1 (tower icon), Macmini9,1 (mini icon).
DEVICE_MODEL=TimeCapsule8,119

# Admin account for the web UI. Pick a strong password.
ADMIN_USER=admin
ADMIN_PASSWORD=changeme-please

# Default per-user Time Machine quota in gigabytes. Can be overridden per
# user in the web UI.
DEFAULT_QUOTA_GB=500

# Timezone used for log timestamps and the UI. IANA TZ database name.
TIMEZONE=UTC

# Logging verbosity. DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Expose Prometheus /metrics on the web UI port. true | false
ENABLE_METRICS=true

# Space-separated list of interfaces Samba binds to. Leave empty for all.
# Useful on hosts with multiple NICs (e.g. bind to eth0 only).
SMB_INTERFACES=

# Web UI port. Change only if 8080 is taken.
WEB_PORT=8080

# Samba port. Change only if you really know what you are doing; macOS
# cannot speak SMB on non-standard ports without manual mount.
SMB_PORT=445
